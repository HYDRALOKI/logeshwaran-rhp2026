1. Longest Common Substring:

#C++

#include <iostream>
#include <string>
using namespace std;

int main()
{
    string s1, s2;
    cin >> s1 >> s2;

    int n = s1.length();
    int m = s2.length();

    int dp[n + 1][m + 1] = {0};

    int mx = 0, endPos = 0;

    for(int i = 1; i <= n; i++)
    {
        for(int j = 1; j <= m; j++)
        {
            if(s1[i - 1] == s2[j - 1])
            {
                dp[i][j] = dp[i - 1][j - 1] + 1;

                if(dp[i][j] > mx)
                {
                    mx = dp[i][j];
                    endPos = i;
                }
            }
            else
            {
                dp[i][j] = 0;
            }
        }
    }

    cout << "Length = " << mx << endl;
    cout << "Substring = " << s1.substr(endPos - mx, mx);

    return 0;
}

