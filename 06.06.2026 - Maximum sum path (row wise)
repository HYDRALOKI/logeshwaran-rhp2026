1.Maximum Sum Path in a Matrix using Dynamic Programming(Row Wise)

#C++

#include <iostream>
using namespace std;

int main()
{
    int n, m;
    cin >> n >> m;

    int a[100][100];
    int dp[100][100];

    // Input matrix
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            cin >> a[i][j];
        }
    }

    
    for(int j = 0; j < m; j++)
    {
        dp[0][j] = a[0][j];
    }

  
    for(int i = 1; i < n; i++)
    {
        int max1 = dp[i-1][0];
        int max2 = -1;
        int maxCol = 0;

       
        for(int j = 1; j < m; j++)
        {
            if(dp[i-1][j] > max1)
            {
                max2 = max1;
                max1 = dp[i-1][j];
                maxCol = j;
            }
            else if(dp[i-1][j] > max2)
            {
                max2 = dp[i-1][j];
            }
        }

      
        for(int j = 0; j < m; j++)
        {
            if(j == maxCol)
                dp[i][j] = a[i][j] + max2;
            else
                dp[i][j] = a[i][j] + max1;
        }
    }


    int ans = dp[n-1][0];

    for(int j = 1; j < m; j++)
    {
        if(dp[n-1][j] > ans)
            ans = dp[n-1][j];
    }

    cout << "Maximum Sum = " << ans;

    return 0;
}

