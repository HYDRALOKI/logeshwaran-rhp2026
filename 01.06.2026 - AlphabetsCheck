1.Bitwise operator  (leftshift concept)

For printing whether all the lower and upper case a-z and A-Z are present or not :

#C++

#include <stdio.h>
#include <stdlib.h>

int main()
{
    char str[1000001];
    scanf("%s", str);

    int lower = 0, upper = 0;

    for(int i = 0; str[i]; i++)
    {
        char ch = str[i];

        
        if(ch >= 'a' && ch <= 'z')
            lower = lower | (1 << (ch - 'a'));

        
        else if(ch >= 'A' && ch <= 'Z')
            upper = upper | (1 << (ch - 'A'));
    }

    
    if(lower == (1<<26)-1 && upper == (1<<26)-1)
        printf("Yes");
    else
        printf("No");

    return 0;
}
