3. Longest Increasing path in a Matrix:

#C++

class Solution {
public:
    int dfs(vector<vector<int>>& a, int i, int j, vector<vector<int>>& dp) {
        if(dp[i][j]) return dp[i][j];

        int n = a.size(), m = a[0].size();
        int ans = 1;
        int d[4][2] = {{1,0},{-1,0},{0,1},{0,-1}};

        for(auto &x : d) {
            int ni = i + x[0], nj = j + x[1];

            if(ni>=0 && nj>=0 && ni<n && nj<m && a[ni][nj] > a[i][j])
                ans = max(ans, 1 + dfs(a, ni, nj, dp));
        }

        return dp[i][j] = ans;
    }

    int longestIncreasingPath(vector<vector<int>>& a) {
        int n = a.size(), m = a[0].size(), ans = 0;
        vector<vector<int>> dp(n, vector<int>(m, 0));

        for(int i=0;i<n;i++)
            for(int j=0;j<m;j++)
                ans = max(ans, dfs(a, i, j, dp));

        return ans;
    }
};
