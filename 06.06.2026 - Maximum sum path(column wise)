2.Maximum Sum Path in a Matrix using Dynamic Programming (Column Wise)

#C++


#include <iostream>
using namespace std;

int main()
{
    int n, m;
    cin >> n >> m;

    int a[100][100];
    int dp[100][100];


    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            cin >> a[i][j];
        }
    }


    for(int i = 0; i < n; i++)
    {
        dp[i][0] = a[i][0];
    }

    
    for(int j = 1; j < m; j++)
    {
        int max1 = dp[0][j-1];
        int max2 = -1;
        int maxRow = 0;

    
        for(int i = 1; i < n; i++)
        {
            if(dp[i][j-1] > max1)
            {
                max2 = max1;
                max1 = dp[i][j-1];
                maxRow = i;
            }
            else if(dp[i][j-1] > max2)
            {
                max2 = dp[i][j-1];
            }
        }

        for(int i = 0; i < n; i++)
        {
            if(i == maxRow)
                dp[i][j] = a[i][j] + max2;
            else
                dp[i][j] = a[i][j] + max1;
        }
    }

    int ans = dp[0][m-1];

    for(int i = 1; i < n; i++)
    {
        if(dp[i][m-1] > ans)
            ans = dp[i][m-1];
    }

    cout << "Maximum Sum = " << ans;

    return 0;
}
